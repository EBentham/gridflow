# Copy to .env and fill in your API keys
# .env is gitignored — never commit secrets

# Elexon BMRS / Insights API
# Register at: https://www.elexonportal.co.uk/
ELEXON_API_KEY=

# ENTSO-E Transparency Platform
# Register at: https://transparency.entsoe.eu/
ENTSOE_API_KEY=

# ENTSO-G Transparency Platform (public — no key required)
# ENTSOG_API_KEY=

# GIE AGSI+ / ALSI (Gas Storage & LNG)
# Register at: https://agsi.gie.eu/ or https://alsi.gie.eu/
GIE_API_KEY=

# NESO / Carbon Intensity API (public — no key required)
# NESO_API_KEY=

# Open-Meteo (public — no key required)
# OPENMETEO_API_KEY=
